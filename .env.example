# хосты postgres/rabbitmq — это имена docker-сервисов (для `make up`).
# Для локального запуска ВНЕ docker замени их на localhost.
DATABASE_URL=postgresql+asyncpg://payments:payments@postgres:5432/payments
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# статический ключ для заголовка X-API-Key
API_KEY=super-secret-api-key

# --- креды контейнеров БД/брокера (должны совпадать с DATABASE_URL/RABBITMQ_URL выше) ---
# их читает docker-compose через ${...} при создании контейнеров postgres/rabbitmq.
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# CORS: список origin'ов через запятую (пусто = только server-to-server)
CORS_ALLOW_ORIGINS=

# сколько последних записей лога держим в памяти для GET /logs
LOG_BUFFER_CAPACITY=1000

# --- эмуляция обработки платежа ---
PROCESSING_MIN_SECONDS=2.0
PROCESSING_MAX_SECONDS=5.0
PROCESSING_SUCCESS_RATE=0.9

# --- ретраи доставки webhook ---
WEBHOOK_TIMEOUT_SECONDS=10.0
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_BACKOFF_BASE_SECONDS=1.0

# --- безопасность webhook ---
WEBHOOK_SIGNING_SECRET=change-me-webhook-signing-secret
# разрешённые схемы (через запятую). для прода оставь только https.
WEBHOOK_ALLOWED_SCHEMES=https,http
# разрешать приватные/loopback хосты как цель webhook. в проде ставь false.
WEBHOOK_ALLOW_PRIVATE_HOSTS=true

# --- rate limiting (fixed window на API-ключ / IP) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# --- message-level retry / DLQ ---
MAX_PROCESSING_ATTEMPTS=3
RETRY_BACKOFF_BASE_SECONDS=2.0

# --- outbox relay (фоновая публикация событий из БД в RabbitMQ) ---
OUTBOX_POLL_INTERVAL=1.0
OUTBOX_BATCH_SIZE=50

# --- топология RabbitMQ (exchange / очереди / routing keys) ---
EXCHANGE_NAME=payments
DLX_NAME=payments.dlx
QUEUE_NEW=payments.new
QUEUE_RETRY=payments.retry
QUEUE_DLQ=payments.dlq
ROUTING_NEW=new
ROUTING_RETRY=retry
ROUTING_DEAD=dead

# --- Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
GF_USERS_DEFAULT_THEME=dark
